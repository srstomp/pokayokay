{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/actions/bridge.py"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/actions/bridge.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|bash|exec_command",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/actions/bridge.py"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "matcher": "Bash|apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/actions/bridge.py"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|apply_patch|Edit|Write|mcp__ohno__.*",
        "hooks": [
          {
            "type": "command",
            "command": "./hooks/actions/bridge.py"
          }
        ]
      }
    ]
  }
}
